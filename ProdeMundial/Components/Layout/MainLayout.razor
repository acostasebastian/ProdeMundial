@inherits LayoutComponentBase
@using ProdeMundial.Domain.Entities
@using ProdeMundial.Web.Services
@inject UserSession Session
@inject IMatchService MatchService
@inject NavigationManager Nav

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
       @*  <div class="top-row px-4 d-flex align-items-center justify-content-between shadow-sm bg-white" style="height: 80px; border-bottom: 2px solid #eee;"> *@
        <div class="top-row px-4 d-flex align-items-center justify-content-between shadow-sm bg-white w-100" style="height: 85px; border-bottom: 2px solid #eee;">
    
            @* GRUPO IZQUIERDO: LOGO + INFO *@
            <div class="d-flex align-items-center">
                @if (!string.IsNullOrEmpty(config.LogoUrl))
                {
                    <div class="bg-dark rounded p-1 me-3 d-flex align-items-center justify-content-center shadow-sm" style="width: 65px; height: 65px;">
                        <img src="@config.LogoUrl" style="max-width: 100%; max-height: 100%; object-fit: contain;" />
                    </div>
                }
                <div>
                    <h4 class="mb-0 fw-bold text-dark" style="font-size: 1.1rem;">@config.CompanyName</h4>
                    <div class="text-primary fw-bold small">
                        <i class="bi bi-trophy-fill"></i> @config.PrizeDescription
                    </div>
                </div>
            </div>

            @* GRUPO DERECHO: SELECTOR *@
         @*    <div class="d-flex align-items-center bg-light px-3 py-2 rounded-pill border">
                <label class="me-2 mb-0 small text-muted d-none d-md-inline">Participando como:</label>
                <select class="form-select form-select-sm border-0 bg-transparent fw-bold"
                        style="width: auto; min-width: 140px; box-shadow: none;"
                        value="@Session.CurrentUser"
                        @onchange="UserSelected">
                    @foreach (var user in usuariosApp)
                    {
                        <option value="@user.Name">@user.Name</option>
                    }
                </select>
            </div> *@
            <div class="d-flex align-items-center bg-light px-3 py-2 rounded-pill border">
                <label class="me-2 mb-0 small text-muted d-none d-md-inline">Participando como:</label>
                <select class="form-select form-select-sm border-0 bg-transparent fw-bold"
                        style="width: auto; min-width: 140px; box-shadow: none;"
                        @onchange="OnUserChanged">
                    @* Volvemos al evento manual *@
    
                    <option value="" disabled selected="@(string.IsNullOrEmpty(Session.CurrentUser))">
                        -- Selecciona tu nombre --
                    </option>
    
                    @foreach (var user in usuariosApp)
                    {
                        <option value="@user.Name" selected="@(Session.CurrentUser == user.Name)">
                            @user.Name
                        </option>
                    }
                </select>
            </div>

          
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    private TournamentConfig config = new();
    private List<AppUser> usuariosApp = new();

    // protected override async Task OnInitializedAsync()
    // {
    //     // Cargamos la configuración de marca y la lista de usuarios reales
    //     config = await MatchService.GetConfigAsync();
    //     usuariosApp = await MatchService.GetUsersAsync();

    //     // Si no hay nadie logueado pero hay usuarios en la DB, elegimos el primero por defecto
    //     if (string.IsNullOrEmpty(Session.CurrentUser) && usuariosApp.Any())
    //     {
    //         Session.ChangeUser(usuariosApp.First().Name);
    //     }
    // }

    private void UserSelected(ChangeEventArgs e)
    {
        var selectedName = e.Value?.ToString();
        if (!string.IsNullOrEmpty(selectedName))
        {
            Session.ChangeUser(selectedName);
            // Opcional: Si quieres que al cambiar de usuario te mande a la Home
            // Nav.NavigateTo("/");
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
        // Nos suscribimos para que si el Admin cambia algo, el Header se entere
        MatchService.OnResultUpdated += async () => await InvokeAsync(async () =>
        {
            await CargarDatos();
            StateHasChanged();
        });
    }

    private async Task CargarDatos()
    {
        config = await MatchService.GetConfigAsync();
        usuariosApp = await MatchService.GetUsersAsync();
    }

    public void Dispose()
    {
        // Muy importante para evitar fugas de memoria
        MatchService.OnResultUpdated -= async () => await InvokeAsync(async () => { await CargarDatos(); StateHasChanged(); });
    }

    private void OnUserChanged(ChangeEventArgs e)
    {    
        var nombreSeleccionado = e.Value?.ToString();
        if (!string.IsNullOrEmpty(nombreSeleccionado))
        {
            // Esto guarda el nombre Y avisa al NavMenu que debe refrescarse
            Session.ChangeUser(nombreSeleccionado);
        
            // Forzamos a este componente actual a redibujarse también
            StateHasChanged();
        }
    }
}