@inherits LayoutComponentBase
@using ProdeMundial.Domain.Entities
@using ProdeMundial.Web.Services
@inject UserSession Session
@inject IMatchService MatchService
@inject NavigationManager Nav
@implements IDisposable

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4 d-flex align-items-center justify-content-between shadow-sm bg-white w-100" style="height: 85px; border-bottom: 2px solid #eee;">
    
            @* GRUPO IZQUIERDO: LOGO + INFO DEL BAR *@
            <div class="d-flex align-items-center">
                @if (!string.IsNullOrEmpty(config.LogoUrl))
                {
                    <div class="bg-dark rounded p-1 me-3 d-flex align-items-center justify-content-center shadow-sm" style="width: 65px; height: 65px;">
                        <img src="@config.LogoUrl" style="max-width: 100%; max-height: 100%; object-fit: contain;" />
                    </div>
                }
                <div>
                    <h4 class="mb-0 fw-bold text-dark" style="font-size: 1.1rem;">@config.Name</h4>
                    <div class="text-primary fw-bold small">
                        <i class="bi bi-trophy-fill"></i> @config.PrizeDescription
                    </div>
                </div>
            </div>

            @* GRUPO DERECHO: USUARIO LOGUEADO + LOGOUT *@
            <div class="d-flex align-items-center">
                @if (Session.IsAuthenticated)
                {
                    <div class="d-flex align-items-center bg-white border rounded-pill shadow-sm px-3 py-1"
                         style="min-width: 200px; height: 50px; justify-content: space-between; border: 1px solid #dee2e6 !important;">
            
                        @* Info del Usuario *@
                        <div class="text-start me-2" style="line-height: 1.1;">
                            <span class="text-muted d-block" style="font-size: 0.6rem; text-transform: uppercase; font-weight: 700;">Participando</span>
                            <span class="fw-bold text-dark" style="font-size: 0.9rem; display: block; max-width: 110px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                @Session.CurrentUser?.Name
                            </span>
                        </div>
            
                        @* Divisor Vertical *@
                        <div style="width: 1px; height: 30px; background-color: #dee2e6; margin: 0 10px;"></div>

                        @* Botón de Logout - Ahora con color explícito y tamaño fijo *@
                        <button class="btn btn-link p-0 m-0 border-0 d-flex align-items-center justify-content-center"
                                @onclick="CerrarSesion"
                                title="Cerrar Sesión"
                                style="text-decoration: none; color: #dc3545 !important; width: 30px; height: 30px;">
                            <i class="bi bi-box-arrow-right" style="font-size: 1.5rem;"></i>
                        </button>
                    </div>
                }
            </div>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    private Company config = new();

    protected override async Task OnInitializedAsync()
    {
        // Suscripción a eventos
        Session.OnUserChanged += HandleUserChanged;
        MatchService.OnResultUpdated += HandleGlobalUpdate;

        await Session.EnsureUserLoadedAsync();

        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        // Cargamos la configuración de la empresa actual según la sesión
        config = await MatchService.GetConfigAsync(Session.CurrentCompanyId);
    }

    private async void HandleUserChanged()
    {
        await InvokeAsync(async () =>
        {
            await CargarDatos();
            StateHasChanged();
        });
    }

    private async void HandleGlobalUpdate()
    {
        await InvokeAsync(async () =>
        {
            await CargarDatos();
            StateHasChanged();
        });
    }

    private async Task CerrarSesion()
    {
        // Cambiamos a la versión asíncrona que limpia el navegador
        await Session.LogoutAsync();
    
        // Nos vamos al login
        Nav.NavigateTo("/login");
    }

    public void Dispose()
    {
        // Limpieza de eventos para evitar Memory Leaks
        Session.OnUserChanged -= HandleUserChanged;
        MatchService.OnResultUpdated -= HandleGlobalUpdate;
    }
}