@page "/ranking"
@using ProdeMundial.Domain
@using ProdeMundial.Domain.Entities
@using ProdeMundial.Web.Services
@inject IMatchService MatchService
@inject UserSession Session
@inject IJSRuntime JSRuntime
@using Microsoft.AspNetCore.SignalR.Client
@implements IAsyncDisposable
@inject NavigationManager NavigationManager


<PageTitle>Ranking - Porra Mundial 2026</PageTitle>

<div class="container mt-4">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold text-primary">📊 Tabla de Posiciones
            <button class="btn btn-sm btn-outline-secondary rounded-circle ms-2"
                    @onclick="ToggleRules" style="width: 30px; height: 30px; padding: 0;">
                <i class="bi bi-info-lg"></i>
            </button>

        </h1>
        <p class="lead">Ranking actualizado de la empresa</p>
    </div>

    <div class="text-center mb-4">    
    
        @if (showRules)
        {
            <div class="alert alert-light border shadow-sm mx-auto animate__animated animate__fadeInDown"
                 style="max-width: 400px; font-size: 0.85rem;">
                <div class="text-end">
                    <button type="button" class="btn-close" @onclick="ToggleRules"></button>
                </div>
                <ul class="text-start list-unstyled mb-0">
                    <li><strong>✅ 3 Puntos:</strong> Resultado exacto (ej: dijiste 2-1 y salió 2-1).</li>
                    <li><strong>✅ 1 Punto:</strong> Acertar ganador o empate (ej: dijiste 1-0 y salió 3-0).</li>
                    <li><strong>⚖️ Desempate:</strong> Si hay igualdad de puntos, sube el que tenga más <strong>resultados exactos</strong>.</li>
                </ul>
            </div>
        }
    </div>

@code {
    private bool showRules = false;
    private void ToggleRules() => showRules = !showRules;    
}

    @if (ranking == null)
    {
        <div class="text-center">
            <div class="spinner-border text-primary" role="status"></div>
            <p>Calculando puntos...</p>
        </div>
    }
    else if (!ranking.Any())
    {
        <div class="alert alert-info text-center">
            Aún no hay partidos finalizados para calcular puntos. ¡Vuelve pronto!
        </div>
    }
    else
    {   
       

    <div class="card shadow border-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-dark text-white">
                @* Cambié a bg-dark para que combine con el logo *@
                <tr>
                    <th class="text-center" style="width: 80px;">Pos</th>
                    <th>Usuario</th>
                    <th class="text-end pe-4">Puntos</th>
                </tr>
            </thead>
            <tbody>              
                @if (ranking != null)
                {                                 
                    // 1. Creamos la lista ordenada de forma segura fuera del HTML
                    var rankingOrdenado = ranking?
                        .OrderByDescending(u => u.TotalPoints)
                        .ThenByDescending(u => u.ExactResults)
                        .ToList() // <--- Convertimos a Lista para que coincida el tipo
                        ?? new List<UserRanking>(); // <--- Si es null, lista vacía

                    @* El "?" y el "?? new List<...>()" aseguran que si no hay datos, no explote *@
                    @foreach (var user in rankingOrdenado)
                    {
                        @* Calculamos posición e identificación (exactamente como antes) *@
                        int posicion = ranking.IndexOf(user) + 1;
                        bool esMiUsuario = user.UserId.Equals(Session.CurrentUser, StringComparison.OrdinalIgnoreCase);

                        @* Mantenemos tu fila original, solo agregamos table-active si eres Tú *@
                        <tr class="@(esMiUsuario ? "table-active" : "")">                   

                            @* 1. Medallas o Número *@
                            <td class="text-center">
                                @if (posicion == 1)
                                {
                                    <span class="fs-4">🥇</span>
                                }
                                else if (posicion == 2)
                                {

                                    <span class="fs-4">🥈</span>
                                }
                                else if (posicion == 3)
                                {

                                    <span class="fs-4">🥉</span>
                                }
                                else
                                {

                                    <span class="fw-bold text-muted">@posicion</span>
                                }
                            </td>
        
                            <td class="align-middle">
                                <div class="d-flex flex-column">
                                    @* Nombre de Usuario (Original) *@
                                    <span class="@(esMiUsuario ? "fw-bold text-primary" : "")">
                                        @user.UserId                                     
                                        @if (esMiUsuario)
                                        {
                                            <span class="badge bg-primary rounded-pill ms-1" style="font-size: 0.6rem;">TÚ</span>
                                        }
                                    </span>
                
                                    @* --- EL PARCHE: Línea de Plenos --- *@
                                    <span class="text-muted small" style="font-size: 0.7rem; margin-top: -2px;">
                                        <i class="bi bi-star-fill text-warning me-1" style="font-size: 0.6rem;"></i>
                                        @user.ExactResults Plenos (@(user.ExactResults * 3) pts)
                                    </span>
                                </div>
                            </td>

                            @* Tu Badge de Puntos (Original - Compacto) *@
                            <td class="text-end align-middle">
                                <span class="badge @(esMiUsuario ? "bg-primary" : "bg-dark") rounded-pill px-3 py-1 fs-6">
                                    @user.TotalPoints pts
                                </span>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    }
</div>


@code {

    private List<UserRanking>? ranking = new();

    private HubConnection? hubConnection;
    private List<UserRanking> rankings; // Lista de Rankings

    protected override async Task OnInitializedAsync()
    {
        // 1. Nos suscribimos al evento del servicio (Cuando el Admin cambia resultados)
        MatchService.OnResultUpdated += HandleRefresh;
        
        // 2. Nos suscribimos al cambio de usuario (Si lo necesitas en esta página)
        Session.OnUserChanged += HandleRefresh;

        await LoadRanking();


        // 2.Configurar el túnel
        hubConnection = new HubConnectionBuilder()
            .WithUrl(NavigationManager.ToAbsoluteUri("/tournamentHub"))
            .Build();

        // 3. Escuchar el aviso del Admin
        hubConnection.On<int>("PartidoFinalizado", async (matchId) =>
        {
            // Cuando un partido termina, recalculamos el ranking
            await LoadRanking();
            
            // Opcional: Podrías tirar un confeti pequeño si el usuario actual
            // está en el puesto #1 después de la actualización.
            
            await InvokeAsync(StateHasChanged);
        });

        await hubConnection.StartAsync();

    }    

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("confetti", new
            {
                particleCount = 150,
                spread = 70,
                origin = new { y = 0.6 },
                zIndex = 999
            });
        }
    }

    private async Task LoadRanking()
    {
        ranking = await MatchService.GetRankingAsync();
        StateHasChanged(); // Aseguramos que se vea el cambio
    }

    // 1. Para eventos que usan Action (sin parámetros)
    private async void HandleRefresh()
    {
        await InvokeAsync(async () => await LoadRanking());
    }

   
    public async ValueTask DisposeAsync()
    {
        /// Limpiamos la suscripción del MatchService (que es Action)
        MatchService.OnResultUpdated -= HandleRefresh;

        // Limpiamos la de Session        
        Session.OnUserChanged -= HandleRefresh;

        // Cerramos SignalR
        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }
    }

   
}
