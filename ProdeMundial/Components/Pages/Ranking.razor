@page "/ranking"
@using ProdeMundial.Domain
@using ProdeMundial.Domain.Entities
@using ProdeMundial.Web.Services
@inject IMatchService MatchService
@inject UserSession Session
@inject IJSRuntime JSRuntime
@using Microsoft.AspNetCore.SignalR.Client
@implements IAsyncDisposable
@inject NavigationManager NavigationManager


<PageTitle>Ranking - Porra Mundial 2026</PageTitle>

<div class="container mt-4">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold text-primary">
            📊 Tabla de Posiciones
            <button class="btn btn-sm btn-outline-secondary rounded-circle ms-2"
                    @onclick="ToggleRules" style="width: 30px; height: 30px; padding: 0;">
                <i class="bi bi-info-lg"></i>
            </button>
        </h1>
        <p class="lead">Ranking actualizado del bar</p>
    </div>

    <div class="text-center mb-4">
        @if (showRules)
        {
            <div class="alert alert-light border shadow-sm mx-auto animate__animated animate__fadeInDown"
                 style="max-width: 480px; position: relative; padding-top: 2rem;">

                <div class="text-end">
                    <button type="button" class="btn-close position-absolute top-0 end-0 m-2" @onclick="ToggleRules"></button>
                </div>

                <InfoPuntos />

            </div>
        }
    </div>

@code {
    private bool showRules = false;
    private void ToggleRules() => showRules = !showRules;    
}

    @if (ranking == null)
    {
        <div class="text-center">
            <div class="spinner-border text-primary" role="status"></div>
            <p>Calculando puntos...</p>
        </div>
    }
    else if (!ranking.Any())
    {
        <div class="alert alert-info text-center">
            Aún no hay partidos finalizados para calcular puntos. ¡Vuelve pronto!
        </div>
    }
    else
    {   
       

    <div class="card shadow border-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-dark text-white">
                @* Cambié a bg-dark para que combine con el logo *@
                <tr>
                    <th class="text-center" style="width: 80px;">Pos</th>
                    <th>Usuario</th>
                    <th class="text-end pe-4">Puntos</th>
                </tr>
            </thead>
            <tbody>              
                @if (ranking != null)
                {                                 
                    // 1. Creamos la lista ordenada de forma segura fuera del HTML
                    //El "?" y el "?? new List<...>()" aseguran que si no hay datos, no explote
                    var rankingOrdenado = ranking?
                        .OrderByDescending(u => u.TotalPoints)
                        .ThenByDescending(u => u.ExactResults)
                        .ToList() // <--- Convertimos a Lista para que coincida el tipo
                        ?? new List<UserRanking>(); // <--- Si es null, lista vacía

                    
                    @foreach (var user in rankingOrdenado)
                    {
                        @* Calculamos posición e identificación *@
                        int posicion = ranking.IndexOf(user) + 1;                        
                        bool esMiUsuario = Session.CurrentUser != null && user.UserId == Session.CurrentUser.Id;
                  
                        <tr class="@(esMiUsuario ? "table-active" : "")">                   

                            @* 1. Medallas o Número *@
                            <td class="text-center">
                                @if (posicion == 1)
                                {
                                    <span class="fs-4">🥇</span>
                                }
                                else if (posicion == 2)
                                {

                                    <span class="fs-4">🥈</span>
                                }
                                else if (posicion == 3)
                                {

                                    <span class="fs-4">🥉</span>
                                }
                                else
                                {

                                    <span class="fw-bold text-muted">@posicion</span>
                                }
                            </td>
        
                            <td class="align-middle">
                                <div class="d-flex flex-column">
                                    @* Nombre de Usuario *@
                                    <span class="@(esMiUsuario ? "fw-bold text-primary" : "")">
                                        @user.UserName                                     
                                        @if (esMiUsuario)
                                        {
                                            <span class="badge bg-primary rounded-pill ms-1" style="font-size: 0.6rem;">TÚ</span>
                                        }
                                    </span>
                
                                    @* --- Línea de Plenos --- *@
                                    <span class="text-muted small" style="font-size: 0.7rem; margin-top: -2px;">
                                        <i class="bi bi-star-fill text-warning me-1" style="font-size: 0.6rem;"></i>
                                    @*     @user.ExactResults Plenos (@(user.ExactResults * 3) pts) *@
                                        @* --- Línea de Plenos modificada --- *@
                                        <span class="text-muted small" style="font-size: 0.7rem; margin-top: -2px;">
                                            <i class="bi bi-star-fill text-warning me-1" style="font-size: 0.6rem;"></i>
                                            @user.ExactResults @(user.ExactResults == 1 ? "Pleno" : "Plenos") acertados
                                        </span>
                                    </span>
                                </div>
                            </td>

                            @* Puntos *@
                            <td class="text-end align-middle">
                                <span class="badge @(esMiUsuario ? "bg-primary" : "bg-dark") rounded-pill px-3 py-1 fs-6">
                                    @user.TotalPoints pts
                                </span>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    }
</div>

@code {
    private List<UserRanking>? ranking = new();
    private HubConnection? hubConnection;
    private bool isReady = false;

    protected override async Task OnInitializedAsync()
    {
        // 1. Suscripción a eventos locales de actualización
        MatchService.OnResultUpdated += HandleRefresh;
        Session.OnUserChanged += HandleRefresh;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // 2. Forzamos a la sesión a despertar y leer el almacenamiento del navegador
            await Session.EnsureUserLoadedAsync();

            // Candado de seguridad interactivo: Si de verdad no hay nadie, al login
            if (!Session.IsAuthenticated)
            {
                NavigationManager.NavigateTo("/login");
                return;
            }

            // 3. Cargamos los datos filtrados por el bar actual
            await LoadRanking();

            // 4. Tiramos el confeti de bienvenida al Ranking
            try
            {
                await JSRuntime.InvokeVoidAsync("confetti", new
                {
                    particleCount = 100,
                    spread = 60,
                    origin = new { y = 0.6 },
                    zIndex = 999
                });
            }
            catch (Exception) { /* Por si JS no está listo */ }

            isReady = true;
            StateHasChanged();

            // 5. Conectamos SignalR en segundo plano para el tiempo real
            await ConectarHub();
        }
    }

    private async Task ConectarHub()
    {
        try
        {
            hubConnection = new HubConnectionBuilder()
                .WithUrl(NavigationManager.ToAbsoluteUri("/tournamentHub"))
                .Build();

            hubConnection.On<int>("PartidoFinalizado", async (matchId) =>
            {
                // Cuando el admin cierra un partido, recalculamos las posiciones del bar en vivo
                await LoadRanking();
            });

            await hubConnection.StartAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine("SignalR Error en Ranking: " + ex.Message);
        }
    }

    private async Task LoadRanking()
    {
        // 🔥 Usamos la propiedad global que nunca falla y está atada al bar actual
        if (Session.CurrentCompanyId > 0)
        {
            ranking = await MatchService.GetRankingAsync(Session.CurrentCompanyId);
            await InvokeAsync(StateHasChanged);
        }
    }

    private async void HandleRefresh()
    {
        await InvokeAsync(async () => await LoadRanking());
    }

    public async ValueTask DisposeAsync()
    {
        // Desuscripción limpia de eventos para evitar fugas de memoria
        MatchService.OnResultUpdated -= HandleRefresh;
        Session.OnUserChanged -= HandleRefresh;

        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }
    }
}
