@page "/ranking"
@using ProdeMundial.Domain
@using ProdeMundial.Domain.Entities
@using ProdeMundial.Web.Services
@inject IMatchService MatchService
@inject UserSession Session
@inject IJSRuntime JSRuntime

<PageTitle>Ranking - Porra Mundial 2026</PageTitle>

<div class="container mt-4">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold text-primary">📊 Tabla de Posiciones
            <button class="btn btn-sm btn-outline-secondary rounded-circle ms-2"
                    @onclick="ToggleRules" style="width: 30px; height: 30px; padding: 0;">
                <i class="bi bi-info-lg"></i>
            </button>

        </h1>
        <p class="lead">Ranking actualizado de la empresa</p>
    </div>

    <div class="text-center mb-4">    
    
        @if (showRules)
        {
            <div class="alert alert-light border shadow-sm mx-auto animate__animated animate__fadeInDown"
                 style="max-width: 400px; font-size: 0.85rem;">
                <div class="text-end">
                    <button type="button" class="btn-close" @onclick="ToggleRules"></button>
                </div>
                <ul class="text-start list-unstyled mb-0">
                    <li><strong>✅ 3 Puntos:</strong> Resultado exacto (ej: dijiste 2-1 y salió 2-1).</li>
                    <li><strong>✅ 1 Punto:</strong> Acertar ganador o empate (ej: dijiste 1-0 y salió 3-0).</li>
                    <li><strong>⚖️ Desempate:</strong> Si hay igualdad de puntos, sube el que tenga más <strong>resultados exactos</strong>.</li>
                </ul>
            </div>
        }
    </div>

@code {
    private bool showRules = false;
    private void ToggleRules() => showRules = !showRules;    
}

    @if (ranking == null)
    {
        <div class="text-center">
            <div class="spinner-border text-primary" role="status"></div>
            <p>Calculando puntos...</p>
        </div>
    }
    else if (!ranking.Any())
    {
        <div class="alert alert-info text-center">
            Aún no hay partidos finalizados para calcular puntos. ¡Vuelve pronto!
        </div>
    }
    else
    {   
       

    <div class="card shadow border-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-dark text-white">
                @* Cambié a bg-dark para que combine con el logo *@
                <tr>
                    <th class="text-center" style="width: 80px;">Pos</th>
                    <th>Usuario</th>
                    <th class="text-end pe-4">Puntos</th>
                </tr>
            </thead>
            <tbody>
                @{
                    int posicion = 1;
                }
                @if (ranking != null)
                {
                    @foreach (var r in ranking)
                    {
                        <tr>
                            @* 1. Medallas o Número *@
                            <td class="text-center">
                                @if (posicion == 1)
                                {
                                    <span class="fs-4">🥇</span>
                                }
                                else if (posicion == 2)
                                {

                                    <span class="fs-4">🥈</span>
                                }
                                else if (posicion == 3)
                                {

                                    <span class="fs-4">🥉</span>
                                }
                                else
                                {

                                    <span class="fw-bold text-muted">@posicion</span>
                                }
                            </td>

                            @* 2. Nombre del Usuario *@
                            <td>
                                <div class="fw-bold text-dark">@r.UserId</div>
                            </td>

                            @* 3. Puntaje y Desempate *@
                            <td class="text-end pe-4">
                                <span class="badge bg-dark rounded-pill fs-6 text-white" style="background-color: #333 !important;">
                                    @r.TotalPoints pts
                                </span>
                            
                                @if (r.ExactResults > 0)
                                {
                                    <div class="text-muted" style="font-size: 0.7rem; font-weight: 500;">
                                        <i class="bi bi-star-fill text-warning me-1"></i>
                                        @r.ExactResults @(r.ExactResults == 1 ? "exacto" : "exactos")
                                    </div>
                                }
                            </td>
                        </tr>
                        posicion++;
                    }
                }
            </tbody>
        </table>
    </div>

    }
</div>


@code {
    private List<UserRanking>? ranking = new();

    protected override async Task OnInitializedAsync()
    {
        // 1. Nos suscribimos al evento del servicio (Cuando el Admin cambia resultados)
        MatchService.OnResultUpdated += HandleRefresh;
        
        // 2. Nos suscribimos al cambio de usuario (Si lo necesitas en esta página)
        Session.OnUserChanged += HandleRefresh;

        await LoadRanking();

    }    

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("confetti", new
            {
                particleCount = 150,
                spread = 70,
                origin = new { y = 0.6 },
                zIndex = 999
            });
        }
    }

    private async Task LoadRanking()
    {
        ranking = await MatchService.GetRankingAsync();
        StateHasChanged(); // Aseguramos que se vea el cambio
    }

    // Usamos un solo método para refrescar todo
    private async void HandleRefresh()
    {
        await InvokeAsync(async () =>
        {
            await LoadRanking();
        });
    }

    public void Dispose()
    {
        // Limpiamos AMBAS suscripciones usando el mismo método que pusimos arriba
        MatchService.OnResultUpdated -= HandleRefresh;
        Session.OnUserChanged -= HandleRefresh;
    }
}
