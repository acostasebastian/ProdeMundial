@page "/admin"
@using Microsoft.AspNetCore.SignalR
@using ProdeMundial.Domain.Entities
@using ProdeMundial.Web.Hubs
@using ProdeMundial.Web.Services
@inject IMatchService MatchService
@inject IJSRuntime JsRuntime
@inject UserSession Session
@inject NavigationManager NavManager
@inject IHubContext<TournamentHub> HubContext

<div class="container mt-4">
    @* <h2 class="mb-4 text-danger"><i class="bi bi-gear-fill"></i> Panel de Administración</h2>
    <p class="text-muted">Carga los resultados oficiales para calcular los puntos.</p> *@
    <div class="container mt-5">
        @* Ese mt-5 (margin top 5) bajará un poco el contenido para que no choque con el header *@
        <div class="text-center mb-4">
            <h2 class="display-4 fw-bold text-primary">Porra Mundial 2026</h2>
            <p class="lead">Ingresa tus pronósticos para la oficina.</p>
        </div>
        
    </div>

    @if (matches == null)
    {
        <p>Cargando partidos...</p>
    }
    else
    {
        <div class="list-group shadow-sm">
            @foreach (var match in matches)
            {
                <div class="list-group-item d-flex align-items-center p-2 p-md-3 mb-2 shadow-sm border rounded">
            
                    <div class="d-flex align-items-center flex-grow-1" style="min-width: 0;">
                
                        <div class="d-flex align-items-center justify-content-end" style="flex: 1; min-width: 0;">
                            <span class="fw-bold me-2 text-uppercase d-none d-md-inline" style="font-size: 0.8rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                @match.HomeTeam.Name
                            </span>
                            <img src="@match.HomeTeam.FlagUrl" width="28" class="shadow-sm rounded flex-shrink-0" />
                        </div>

                        <div class="d-flex align-items-center justify-content-center px-2" style="width: 110px;">
                            <input type="number" @bind="adminHomeScores[match.Id]" class="marcador-input" style="width: 40px; height: 40px; font-size: 1rem;" />
                            <span class="mx-1 fw-bold text-muted">-</span>
                            <input type="number" @bind="adminAwayScores[match.Id]" class="marcador-input" style="width: 40px; height: 40px; font-size: 1rem;" />
                        </div>

                        <div class="d-flex align-items-center justify-content-start" style="flex: 1; min-width: 0;">
                            <img src="@match.AwayTeam.FlagUrl" width="28" class="shadow-sm rounded flex-shrink-0" />
                            <span class="fw-bold ms-2 text-uppercase d-none d-md-inline" style="font-size: 0.8rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                @match.AwayTeam.Name
                            </span>
                            @if (match.IsFinished)
                            {
                                <i class="bi bi-check-circle-fill text-success ms-1 d-none d-sm-inline"></i>
                            }
                        </div>
                    </div>

                    <div class="ms-2 ms-md-3 ps-2 ps-md-3 border-start">
                        <button class="btn @(match.IsFinished ? "btn-outline-secondary" : "btn-danger") fw-bold btn-sm"
                                style="width: 70px; font-size: 0.75rem;"
                                @onclick="() => SaveResult(match.Id)">
                            @(match.IsFinished ? "EDITAR" : "LISTO")
                        </button>
                    </div>
            
                </div>
            }
        </div>

    }

    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="text-danger mb-0"><i class="bi bi-gear-fill"></i> Panel de Control</h2>
        
            <div class="btn-group shadow-sm">
                <button class="btn btn-outline-primary" @onclick="SimulateResults">
                    <i class="bi bi-dice-5"></i> Simular Todo
                </button>               
                <button class="btn btn-outline-danger" @onclick="() => showResetModal = true">
                    <i class="bi bi-trash"></i> Resetear Torneo
                </button>
            </div>
        </div>

    </div>

</div>

@if (showResetModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow-lg border-0">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">⚠️ Confirmar Reset</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showResetModal = false"></button>
                </div>
                <div class="modal-body text-center p-4">
                    <p class="fs-5">¿Qué deseas resetear exactamente?</p>
                    <div class="form-check form-switch d-inline-block text-start mb-3">
                        <input class="form-check-input" type="checkbox" id="checkPred" @bind="deletePredictions">
                            <label class="form-check-label fw-bold" for="checkPred">¿Borrar también las predicciones de usuarios?</label>
                        </div>
                        <p class="text-muted small">Esta acción no se puede deshacer.</p>
                    </div>
                    <div class="modal-footer justify-content-center border-0 pb-4">
                        <button type="button" class="btn btn-secondary px-4" @onclick="() => showResetModal = false">Cancelar</button>
                        <button type="button" class="btn btn-danger px-4" @onclick="ConfirmReset">Ejecutar Reset</button>
                    </div>
                </div>
            </div>
        </div>
    }

@code {
    private List<Match>? matches;
    // Usamos dos diccionarios simples para evitar el error de la tupla
    private Dictionary<int, int> adminHomeScores = new();
    private Dictionary<int, int> adminAwayScores = new();

    private bool showResetModal = false;
    private bool deletePredictions = false;

    protected override async Task OnInitializedAsync()
    {


        if (Session.CurrentUser?.ToLower() != "sebastian")
        {
            // Si no es Sebastian, lo mandamos de patitas a la Home
            NavManager.NavigateTo("/");
        }

        matches = await MatchService.GetUpcomingMatchesAsync();
        if (matches != null)
        {
            foreach (var m in matches)
            {
                adminHomeScores[m.Id] = m.HomeScore ?? 0;
                adminAwayScores[m.Id] = m.AwayScore ?? 0;
            }            
        }
    }

    private async Task SaveResult(int id)
    {   

        // 1. Guardamos en la DB
        await MatchService.UpdateMatchResultAsync(id, adminHomeScores[id], adminAwayScores[id]);

        // 2. ACTUALIZACIÓN LOCAL: En lugar de re-pedir toda la lista,
        // modificamos el partido en la lista actual de la pantalla.
        var match = matches.FirstOrDefault(m => m.Id == id);
        if (match != null)
        {
            match.IsFinished = true; // Marcamos como terminado para que el botón cambie a "EDITAR"
            match.HomeScore = adminHomeScores[id];
            match.AwayScore = adminAwayScores[id];
        }

        // 3. SignalR: Avisamos a los demás
        await HubContext.Clients.All.SendAsync("PartidoFinalizado", id);

        // 4. Forzamos a Blazor a redibujar
        StateHasChanged();
    }


    private async Task SimulateResults()
    {
        if (await JsRuntime.InvokeAsync<bool>("confirm", "¿Quieres simular resultados aleatorios para todos los partidos?"))
        {
            await MatchService.SimulateAllMatchesAsync();
            matches = await MatchService.GetUpcomingMatchesAsync(); // Refrescar lista local
        }
    }

    private async Task ResetResults()
    {
        if (await JsRuntime.InvokeAsync<bool>("confirm", "ESTO BORRARÁ TODOS LOS RESULTADOS OFICIALES. ¿Continuar?"))
        {
            await MatchService.ResetTournamentAsync(deletePredictions);
            matches = await MatchService.GetUpcomingMatchesAsync(); // Refrescar lista local
        }
    }

    private async Task ConfirmReset()
    {
        await MatchService.ResetTournamentAsync(deletePredictions);
        showResetModal = false; // Cerramos el modal
        
        // Refrescamos la lista de la pantalla de admin
        matches = await MatchService.GetUpcomingMatchesAsync();
        StateHasChanged();
    }
}
}
