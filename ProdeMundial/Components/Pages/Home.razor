    public void Dispose()
    {
        Session.OnUserChanged -= HandleUserChanged;
        MatchService.OnPredictionsCleared -= HandleUserChanged;
        MatchService.OnResultUpdated -= HandleUserChanged;
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }
        Dispose();
    }

    private async Task VerificarMiEstadoAsync()
    {
        if (Session.CurrentUser == null) return;

        try
        {
            var usuarioFresco = await MatchService.GetUserByIdAsync(Session.CurrentUser.Id);

            if (usuarioFresco != null && usuarioFresco.IsActive)
            {
                Session.CurrentUser.IsActive = true;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error al verificar estado: {ex.Message}");
        }
    }

    
    private void OnGolesCambiados(Match match)
    {
        // Verificamos que ambos tengan datos cargados en los diccionarios
        if (homeScores.TryGetValue(match.Id, out var golesLocal) &&
            awayScores.TryGetValue(match.Id, out var golesVisita))
        {
            if (golesLocal.HasValue && golesVisita.HasValue)
            {
                if (golesLocal > golesVisita)
                {
                    clasificadosPenales[match.Id] = match.HomeTeamId; // Gana Local automáticamente
                }
                else if (golesVisita > golesLocal)
                {
                    clasificadosPenales[match.Id] = match.AwayTeamId; // Gana Visita automáticamente
                }
                else
                {
                    // Es empate: limpiamos para obligar al usuario a elegir con el botón en la UI
                    clasificadosPenales[match.Id] = null;
                }
            }
        }
    }

