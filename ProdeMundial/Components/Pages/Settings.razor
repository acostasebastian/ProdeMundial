@page "/settings"
@using ProdeMundial.Domain.Entities
@using ProdeMundial.Web.Services
@inject IMatchService MatchService
@inject IFileService FileService
@inject UserSession Session
@inject NavigationManager NavManager

<div class="container mt-4">
    <h2 class="mb-4"><i class="bi bi-gear-fill"></i> Panel de Control - @config.Name</h2>

    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white fw-bold d-flex justify-content-between align-items-center">
                    🎨 Personalización de Marca
                    @if (Session.CurrentUser?.IsAdmin ?? false)
                    {
                        <span class="badge bg-primary">Admin</span>
                    }
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label fw-bold small">Nombre del Negocio / Bar</label>
                        <input type="text" class="form-control" @bind="config.Name" />
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold small">Logo de la Empresa</label>
                        <InputFile OnChange="HandleFileSelected" class="form-control form-control-sm" accept=".jpg,.jpeg,.png" />
                        
                        @if (!string.IsNullOrEmpty(config.LogoUrl))
                        {
                            <div class="mt-2 position-relative d-inline-block">
                                <img src="@config.LogoUrl" class="rounded shadow-sm" style="height: 80px; width: 80px; object-fit: cover;" />
                                <button class="btn btn-sm btn-danger position-absolute top-0 end-0 m-1" @onclick="LimpiarLogo">
                                    <i class="bi bi-x"></i>
                                </button>
                            </div>
                        }
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold small">Descripción del Premio</label>
                        <textarea class="form-control" rows="3" @bind="config.PrizeDescription" placeholder="Ej: Un barril de cerveza..."></textarea>
                    </div>

                    @if (Session.CurrentUser?.Name == "Sebastian")
                    {
                        <div class="bg-light p-2 rounded mb-3 border">
                            <label class="form-label fw-bold small text-primary">Cupo Máximo (SaaS)</label>
                            <input type="number" class="form-control form-control-sm" @bind="config.MaxUsers" />
                            <label class="form-label fw-bold small text-primary mt-2">Código de Invitación</label>
                            <input type="text" class="form-control form-control-sm" @bind="config.InvitationCode" />
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(mensajeFeedback))
                    {
                        <div class="alert @claseFeedback p-2 text-center small shadow-sm animate__animated animate__fadeIn">
                            @mensajeFeedback
                        </div>
                    }

                    <button class="btn btn-primary w-100" @onclick="GuardarConfig">
                        <i class="bi bi-save"></i> Guardar Configuración
                    </button>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white fw-bold d-flex justify-content-between">
                    👥 Participantes (@usuariosApp.Count / @config.MaxUsers)
                    <span class="small">Invitación: <b>@config.InvitationCode</b></span>
                </div>
                <div class="card-body">
                    <div class="list-group list-group-flush border rounded" style="max-height: 450px; overflow-y: auto;">
                        @if (!usuariosApp.Any())
                        {
                            <div class="p-4 text-center text-muted italic">No hay usuarios registrados</div>
                        }
                        else
                        {
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h4 class="fw-bold mb-0">Participantes del Bar</h4>
    
                                <!-- Botón de Activación Masiva -->
                                @if (usuariosApp != null && usuariosApp.Any(u => !u.IsActive))
                                {
                                    <button class="btn btn-success btn-sm fw-bold rounded-pill px-3" @onclick="ActivarTodosLosPendientes">
                                        <i class="bi bi-check-all me-1"></i> Activar Todos los Pendientes
                                    </button>
                                }
                            </div>

                            @foreach (var u in usuariosApp)
                            {
                                <div class="list-group-item d-flex justify-content-between align-items-center">
                                    <div>
                                        <div class="fw-bold">@u.Name</div>
                                        <small class="text-muted">ID: @u.PhoneNumber</small>
                                    </div>
                                    <div class="d-flex gap-2 align-items-center">
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" checked="@u.IsActive"
                                                   @onchange="@(async (e) => await ToggleActivacion(u))">
                                                <label class="small @(u.IsActive ? "text-success fw-bold" : "text-danger")">
                                                    @(u.IsActive ? "PAGO" : "PEND")
                                                </label>
                                            </div>
                                        
                                            <button class="btn btn-sm btn-outline-danger border-0" @onclick="() => BorrarUsuario(u.Id)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

@code {
    private Company config = new();
    private List<AppUser> usuariosApp = new();
    private string mensajeFeedback = "";
    private string claseFeedback = "";
    private bool cargando = true; // Agregamos un estado de carga

    protected override async Task OnInitializedAsync()    
    {
        config = await MatchService.GetConfigAsync(Session.CurrentCompanyId);
        await CargarUsuarios();
    }
    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // 🔥 Rehidratamos la sesión directo del almacenamiento del navegador de forma segura
            await Session.EnsureUserLoadedAsync();

            // Candado absoluto: Si no inició sesión o no es administrador, rebota a la Home
            if (Session.CurrentUser == null || !Session.CurrentUser.IsAdmin)
            {
                var returnUrl = NavManager.ToBaseRelativePath(NavManager.Uri);
                NavManager.NavigateTo($"/login?returnUrl={returnUrl}");
                return;
            }

            // Cargamos los datos del bar basados en la sesión confirmada
            config = await MatchService.GetConfigAsync(Session.CurrentCompanyId);
            await CargarUsuarios();
        
            cargando = false;
            StateHasChanged();
        }
    }


    private async Task CargarUsuarios()
    {
        // Importante: Usar el nuevo método filtrado que creamos antes
        usuariosApp = await MatchService.GetUsersByCompanyAsync(Session.CurrentCompanyId);
    }

    private async Task GuardarConfig()
    {
        try
        {
            await MatchService.UpdateCompanyAsync(config);
            MostrarFeedback("✅ Configuración actualizada", "alert-success");           
            await Session.LoginAsync(Session.CurrentUser!, config.Id); // Refresca Layout y persiste en navegador
            
        }
        catch (Exception)
        {
            MostrarFeedback("❌ Error al guardar", "alert-danger");
        }
    }

    private async Task ToggleActivacion(AppUser user)
    {
        user.IsActive = !user.IsActive;
        await MatchService.UpdateUserStatusAsync(user); 
        await CargarUsuarios();
        StateHasChanged();
    }

    private async Task BorrarUsuario(int id)
    {
        await MatchService.DeleteUserAsync(id);
        await CargarUsuarios();
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        var path = await FileService.UploadLogoAsync(e.File);
        if (path != null)
        {
            config.LogoUrl = path;
            MostrarFeedback("📸 Logo cargado. ¡No olvides guardar!", "alert-info");
        }
    }

    private void LimpiarLogo() => config.LogoUrl = "/img/default-logo.png";

    private void MostrarFeedback(string mensaje, string clase)
    {
        mensajeFeedback = mensaje;
        claseFeedback = clase;
        StateHasChanged();
        Task.Delay(3000).ContinueWith(_ => { mensajeFeedback = ""; InvokeAsync(StateHasChanged); });
    }

    private async Task ActivarTodosLosPendientes()
    {
        try
        {
            // Llamamos al servicio pasando el ID de la compañía actual de la sesión
            int totalActivados = await MatchService.ActivateAllPendingUsersAsync(Session.CurrentCompanyId);
        
            if (totalActivados > 0)
            {
                // Refrescamos la lista local para que impacte visualmente en la pantalla
                await CargarUsuarios();
                StateHasChanged();
            
                Console.WriteLine($"🚀 Se activaron {totalActivados} usuarios correctamente.");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error al activar usuarios masivamente: {ex.Message}");
        }
    }
}