@page "/login"
@using ProdeMundial.Domain.Entities
@using ProdeMundial.Web.Services
@inject UserSession Session
@inject IMatchService MatchService
@inject NavigationManager Nav

@if (isReady && Session.CurrentUser == null)
{
    <div class="container d-flex justify-content-center align-items-center" style="min-height: 80vh;">
        <div class="card shadow-lg border-0" style="max-width: 400px; width: 100%;">
            <div class="card-body p-5 text-center">
                <h2 class="fw-bold mb-4">🏆 ¡Bienvenido!</h2>
                <p class="text-muted mb-4">Ingresa el código de invitación y tus datos para empezar.</p>

                <EditForm Model="@loginModel" OnValidSubmit="HandleLogin">
                    <div class="form-floating mb-3">
                        <InputText @bind-Value="loginModel.Identity" class="form-control" id="id" placeholder="Teléfono o Email" />
                        <label for="id">Teléfono o Email</label>
                    </div>

                    <div class="form-floating mb-4">
                        <InputText @bind-Value="loginModel.Pin" type="password" class="form-control" id="pin" placeholder="PIN" />
                        <label for="pin">PIN de acceso</label>
                    </div>

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger p-2 small mb-3">@errorMessage</div>
                    }

                    <button type="submit" class="btn btn-primary w-100 py-3 fw-bold rounded-pill">INGRESAR</button>
                    <div class="mt-3">
                        <a href="/register" class="text-decoration-none">¿Eres nuevo? Regístrate aquí</a>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}
else
{
    <div class="d-flex flex-column justify-content-center align-items-center" style="min-height: 80vh;">
        <div class="spinner-border text-primary" role="status"></div>
        <span class="ms-2 text-muted mt-2 fw-bold">Cargando tu panel...</span>
    </div>
}

@code {
    private LoginRequest loginModel = new();
    private string? errorMessage;
    private bool isReady = false; // 🔥 Control de carga inicial
    
    [Parameter][SupplyParameterFromQuery] public string? returnUrl { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // 1. Forzamos a leer el LocalStorage del navegador tras el refresco
            await Session.EnsureUserLoadedAsync();

            // 2. Si resulta que YA está logueado, lo sacamos del login eyectado
            if (Session.CurrentUser != null)
            {
                if (!string.IsNullOrEmpty(returnUrl))
                {
                    var destination = returnUrl.StartsWith("/") ? returnUrl : "/" + returnUrl;
                    Nav.NavigateTo(destination);
                }
                else
                {
                    // Si es SuperAdmin va a su panel, si no a la Home normal del bar
                    Nav.NavigateTo(Session.IsSuperAdmin ? "/superadmin" : "/");
                }
                return;
            }

            // 3. Si no hay nadie logueado, habilitamos el formulario
            isReady = true;
            StateHasChanged();
        }
    }

    private async Task HandleLogin()
    {
        errorMessage = null;
        string identityLimpia = loginModel.Identity.Trim();
        
        if (!identityLimpia.Contains("@"))
        {
            identityLimpia = new string(identityLimpia.Where(char.IsDigit).ToArray());
        }
        else
        {
            identityLimpia = identityLimpia.ToLower();
        }
        
        if (string.IsNullOrEmpty(identityLimpia) || string.IsNullOrEmpty(loginModel.Pin))
        {
            errorMessage = "Por favor, completa todos los campos.";
            return;
        }
        
        var user = await MatchService.AuthenticateUserWithoutCodeAsync(identityLimpia, loginModel.Pin);

        if (user != null)
        {
            await Session.LoginAsync(user, user.CompanyId);
                            
            if (!string.IsNullOrEmpty(returnUrl))
            {
                var destination = returnUrl.StartsWith("/") ? returnUrl : "/" + returnUrl;
                Nav.NavigateTo(destination);
            }
            else
            {
                Nav.NavigateTo(Session.IsSuperAdmin ? "/superadmin" : "/");
            }
        }
        else
        {
            errorMessage = "⚠️ Usuario o PIN incorrectos.";
        }
    }

    public class LoginRequest
    {
        public string InvitationCode { get; set; } = string.Empty;
        public string Identity { get; set; } = string.Empty;
        public string Pin { get; set; } = string.Empty;
    }
}